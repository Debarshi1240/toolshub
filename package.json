{
  "name": "toolshub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend": "cd apps/backend && npm run dev",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:backend": "cd apps/backend && npm run build",
    "lint": "cd apps/frontend && npm run lint && cd ../backend && npm run lint",
    "install:all": "npm install && cd apps/downloader && pip install -r requirements.txt"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
